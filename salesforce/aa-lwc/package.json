{
  "name": "aa-lwc",
  "version": "1.0.0",
  "description": "Now that you've created a Salesforce DX project, what's next? Here are some documentation resources to get you started.",
  "main": "index.js",
  "scripts": {
    "generate-static-resources": "./setup.sh generate-static-resources",
    "login": "sf org login web --alias ProdOrg && sf config set target-org ProdOrg",
    "deploy": "sf project deploy start --target-org ProdOrg",
    "login-devhub": "./setup.sh login-devhub",
    "setup-scratch": "./setup.sh setup-scratch",
    "deploy-scratch": "./setup.sh deploy-scratch",
    "teardown-scratch": "./setup.sh teardown-scratch",
    "test": "sfdx-lwc-jest -- --forceExit --detectOpenHandles"
  },
  "author": "Jordan",
  "license": "Apache-2.0",
  "devDependencies": {
    "@salesforce/lwc-dev-server": "^2.11.0",
    "@salesforce/sfdx-lwc-jest": "^5.1.0",
    "cross-fetch": "^4.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier-plugin-apex": "^2.1.4"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  },
  "overrides": {
    "@lwc/template-compiler": {
      "@babel/traverse": "7.23.2"
    },
    "reload": {
      "ws": "8.17.1"
    },
    "@salesforce/core": {
      "jsonwebtoken": "9.0.0"
    },
    "@lwc/compiler": {
      "json5": "1.0.2"
    },
    "terser": "4.8.1",
    "rollup": "2.79.2",
    "postcss": "8.4.31",
    "path-to-regexp": "6.3.0",
    "nth-check": "2.0.1",
    "axios": "1.7.4",
    "body-parser": "1.20.3",
    "http-proxy-middleware": "2.0.7",
    "braces": "3.0.3",
    "cookie": "0.7.1",
    "@oclif/plugin-help": "3.2.4"
  }
}
